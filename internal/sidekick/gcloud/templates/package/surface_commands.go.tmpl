package {{.PackageName}}

import (
	"context"
	"fmt"

{{if .Imports}}{{range .Imports}}	{{if .Alias}}{{.Alias}} {{end}}"{{.Path}}"
{{end}}	"google.golang.org/protobuf/encoding/protojson"
{{end}}	"github.com/urfave/cli/v3"
)

// Command returns the {{.PackageName}} command tree for inclusion under the gcloud root.
func Command() *cli.Command {
	return &cli.Command{
		Name:  "{{.Group.Name}}",
		Usage: "{{.Group.Usage}}",
		Commands: []*cli.Command{
			{{- range .Group.Subgroups}}
			{
				Name:  "{{.Name}}",
				Usage: "{{.Usage}}",
				Commands: []*cli.Command{
					{{- range .Commands}}
					{{template "command" .}},
					{{- end}}
				},
			},
			{{- end}}
			{{- range .Group.Commands}}
			{{template "command" .}},
			{{- end}}
		},
	}
}

{{- define "command" -}}
{
	Name:  "{{.Name}}",
	Usage: "{{.Usage}}",
	{{- if .Flags}}
	Flags: []cli.Flag{
		{{- range .Flags}}
		&cli.{{.Kind}}Flag{Name: "{{.Name}}", Usage: "{{.Usage}}", Required: {{.Required}}},
		{{- end}}
	},
	{{- end}}
	Action: func(ctx context.Context, cmd *cli.Command) error {
		{{- if .ClientCall}}
		{{- if .RequiresProject}}
		if cmd.String("project") == "" {
			return fmt.Errorf("--project is required")
		}
		{{- end}}
		{{.PathLabel}} := fmt.Sprintf("{{.PathFormat}}", {{.PathFormatArgs}})
		client, err := {{.ClientCall.Package}}.NewClient(ctx)
		if err != nil {
			return err
		}
		defer client.Close()
		{{- if .ClientCall.IsList}}
		it := client.{{.ClientCall.Method}}(ctx, &{{.ClientCall.RequestType}}{ {{.ClientCall.NameField}}: {{.PathLabel}} })
		for {
			resp, err := it.Next()
			if err == iterator.Done {
				break
			}
			if err != nil {
				return err
			}
			out, err := protojson.MarshalOptions{Multiline: true, Indent: "  "}.Marshal(resp)
			if err != nil {
				return err
			}
			fmt.Println(string(out))
		}
		return nil
		{{- else if .ClientCall.IsDelete}}
		{{- if .ClientCall.IsLRO}}
		op, err := client.{{.ClientCall.Method}}(ctx, &{{.ClientCall.RequestType}}{ {{.ClientCall.NameField}}: {{.PathLabel}} })
		if err != nil {
			return err
		}
		if err := op.Wait(ctx); err != nil {
			return err
		}
		{{- else}}
		if err := client.{{.ClientCall.Method}}(ctx, &{{.ClientCall.RequestType}}{ {{.ClientCall.NameField}}: {{.PathLabel}} }); err != nil {
			return err
		}
		{{- end}}
		fmt.Printf("Deleted %s\n", {{.PathLabel}})
		return nil
		{{- else}}
		resp, err := client.{{.ClientCall.Method}}(ctx, &{{.ClientCall.RequestType}}{ {{.ClientCall.NameField}}: {{.PathLabel}} })
		if err != nil {
			return err
		}
		out, err := protojson.MarshalOptions{Multiline: true, Indent: "  "}.Marshal(resp)
		if err != nil {
			return err
		}
		fmt.Println(string(out))
		return nil
		{{- end}}
		{{- else if .HasPath}}
		{{- if .RequiresProject}}
		if cmd.String("project") == "" {
			return fmt.Errorf("--project is required")
		}
		{{- end}}
		{{.PathLabel}} := fmt.Sprintf("{{.PathFormat}}", {{.PathFormatArgs}})
		fmt.Printf("Executing {{.Name}} on %s\n", {{.PathLabel}})
		return nil
		{{- else}}
		fmt.Println("Executing {{.Name}}...")
		return nil
		{{- end}}
	},
}
{{- end}}
